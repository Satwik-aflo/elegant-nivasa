---
// Shared sub-site chrome + sections; the per-angle hero comes in via the
// default <slot/>. Styling/behaviour from /assets/css/site.css +
// /assets/js/site.js (in public/). (Originally ported from a hand-coded static
// HTML site that has since been deleted — recoverable from git history.)
import AnalyticsScripts from "../components/AnalyticsScripts.astro";
import Scoreboard from "../components/Scoreboard.astro";
import AngleLeadCost from "../components/AngleLeadCost.astro";
import AngleLeadHandover from "../components/AngleLeadHandover.astro";
import AngleLeadYield from "../components/AngleLeadYield.astro";
import { site } from "../config/site.ts";
import { ANGLES, type Angle } from "../data/comparison.ts";
interface Props {
  title: string;
  description: string;
  /** Canonical Angle key (ADR-0002): cost | handover | yield. */
  angle: Angle;
  adSet: string;
}
const { title, description, angle, adSet } = Astro.props;
// WhatsApp message text is baked in at build time per Angle (single source);
// site.js interpolates {rep} and decodes the anti-scrape number at runtime.
const waMessage = ANGLES[angle].waMessage;
// Anti-scrape (CLAUDE.md §3): never ship the raw number in markup. Base64 it
// at build time; site.js decodes it at runtime (atob) to build the wa.me link.
// Use btoa (Web API) not Buffer — the Cloudflare runtime has no Node Buffer.
const enc = (s: string) => btoa(s);
// WhatsApp glyph reused by both rep buttons.
const waSvg = `<svg viewBox="0 0 32 32" width="21" height="21" fill="currentColor" aria-hidden="true"><path d="M16 .4C7.4.4.5 7.3.5 15.9c0 2.8.7 5.4 2 7.8L.4 31.6l8.1-2.1c2.3 1.2 4.8 1.9 7.5 1.9 8.6 0 15.5-6.9 15.5-15.5S24.6.4 16 .4zm0 28.3c-2.4 0-4.7-.6-6.7-1.8l-.5-.3-4.8 1.3 1.3-4.7-.3-.5a12.7 12.7 0 0 1-1.9-6.8C2.4 8.4 8.5 2.4 16 2.4s13.6 6 13.6 13.5S23.5 28.7 16 28.7zm7.4-9.5c-.4-.2-2.4-1.2-2.7-1.3-.4-.1-.6-.2-.9.2-.3.4-1 1.3-1.2 1.5-.2.2-.4.3-.8.1-.4-.2-1.7-.6-3.3-2-.1-.1-1.5-1.3-1.5-2.8 0-.4.2-.6.4-.8.2-.2.4-.4.5-.7.2-.2.2-.4.4-.7.1-.3 0-.5 0-.7-.1-.2-.9-2.1-1.2-2.9-.3-.7-.6-.6-.9-.6h-.7c-.2 0-.6.1-1 .5-.3.4-1.3 1.3-1.3 3.1s1.3 3.6 1.5 3.9c.2.2 2.6 4 6.3 5.5.9.4 1.6.6 2.1.8.9.3 1.7.2 2.3.1.7-.1 2.4-1 2.7-1.9.3-.9.3-1.7.2-1.9-.1-.2-.3-.2-.7-.4z"/></svg>`;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content="noindex, nofollow" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/assets/css/site.css" />
<AnalyticsScripts />
</head>
<body data-angle={angle}>

<!-- ============ HEADER ============ -->
<header class="site-header">
  <a class="brand" href="/" aria-label="Elegant Nivasa home">
    <img src="/assets/img/brand/nivasa-logo.png" alt="Elegant Nivasa" />
  </a>
  <button class="nav-toggle" aria-label="Menu" aria-expanded="false"><span></span><span></span><span></span></button>
  <nav class="nav">
    <a href="#angle">Why Nivasa</a>
    <a href="#value">Full comparison</a>
    <a href="#emi">EMI</a>
    <a class="btn btn--teal" href="#reps">Enquire</a>
    <a class="btn btn--gold" href="#enquire" data-book>Book a visit</a>
  </nav>
</header>

<!-- ============ HERO (per-angle; layout + image owned by the page) ============ -->
<slot />

<!-- ============ ANGLE-LEAD (bespoke per Angle — leads the page, ADR-0002 B2) ============ -->
{angle === "cost" && <AngleLeadCost />}
{angle === "handover" && <AngleLeadHandover />}
{angle === "yield" && <AngleLeadYield />}

<!-- ============ FULL SCOREBOARD (supporting; identical on every Sub-site) ============ -->
<Scoreboard />

<!-- ============ EMI / AFFORDABILITY CALCULATOR ============ -->
<section class="section" id="emi">
  <div class="wrap">
    <div class="shead reveal">
      <p class="eyebrow">Plan your home</p>
      <h2 class="h2">See exactly what you can afford.</h2>
      <p class="lead">Two quick tools — find the Nivasa home your income qualifies for, or see how little more than your rent it takes to own one.</p>
    </div>
    <div class="calc reveal d1" data-calc>
      <div class="calc-tabs" role="tablist">
        <button type="button" class="calc-tab active" data-mode="afford">What can I afford?</button>
        <button type="button" class="calc-tab" data-mode="rent">Already paying rent?</button>
      </div>

      <!-- AFFORDABILITY -->
      <div class="emi calc-panel" data-panel="afford">
        <div class="emi-controls">
          <div class="field">
            <div class="field-top"><label for="aff-income">Your monthly income</label><span class="fval" id="aff-income-val"></span></div>
            <input class="input" id="aff-income" type="number" min="0" max="10000000" step="5000" inputmode="numeric" value="200000" />
          </div>
          <label class="check" for="aff-co"><input type="checkbox" id="aff-co" /> Add another earning family member</label>
          <div class="field co-field" id="aff-co-wrap" hidden>
            <div class="field-top"><label for="aff-co-income">Co-applicant monthly income</label><span class="fval" id="aff-co-val"></span></div>
            <input class="input" id="aff-co-income" type="number" min="0" max="10000000" step="5000" inputmode="numeric" value="100000" />
          </div>
          <div class="field">
            <div class="field-top"><label for="aff-existing">Existing EMIs / obligations</label><span class="fval" id="aff-emi-val"></span></div>
            <input class="input" id="aff-existing" type="number" min="0" max="1000000" step="1000" inputmode="numeric" value="0" />
          </div>
          <div class="field">
            <div class="field-top"><label for="aff-foir">EMI from income</label><span class="fval" id="aff-foir-val"></span></div>
            <input id="aff-foir" type="range" min="40" max="50" value="45" step="1" />
          </div>
          <div class="field">
            <div class="field-top"><label for="aff-rate">Interest rate</label><span class="fval" id="aff-rate-val"></span></div>
            <input id="aff-rate" type="range" min="7" max="12" value="8.5" step="0.1" />
          </div>
          <div class="field">
            <div class="field-top"><label for="aff-ten">Loan tenure</label><span class="fval" id="aff-ten-val"></span></div>
            <input id="aff-ten" type="range" min="5" max="30" value="20" step="1" />
          </div>
          <div class="field">
            <div class="field-top"><label for="aff-dp">Down payment</label><span class="fval" id="aff-dp-val"></span></div>
            <input id="aff-dp" type="range" min="10" max="40" value="20" step="1" />
          </div>
        </div>
        <div class="emi-result">
          <span class="k">You could be eligible for</span>
          <div class="emi-big" id="aff-loan">₹0</div>
          <span class="k normal">home loan · on a <span id="aff-budget">₹0</span> total budget</span>
          <div class="emi-break">
            <div class="b"><div class="bv" id="aff-maxemi">₹0</div><div class="bl">Monthly EMI you can service</div></div>
            <div class="b"><div class="bv" id="aff-dpamt">₹0</div><div class="bl">Down payment needed</div></div>
            <div class="b"><div class="bv" id="aff-area">0 sft</div><div class="bl">Affordable size</div></div>
            <div class="b"><div class="bv" id="aff-income-tot">₹0</div><div class="bl">Income considered</div></div>
          </div>
          <div class="aff-fit" id="aff-fit"></div>
          <p class="emi-note">Indicative eligibility at 40–50% of income toward EMI (bank FOIR). Final sanction depends on your lender, profile &amp; documents.</p>
        </div>
      </div>

      <!-- RENT VS OWN -->
      <div class="emi calc-panel" data-panel="rent" hidden>
        <div class="emi-controls">
          <div class="field">
            <div class="field-top"><label for="rnt-rent">Rent you pay now</label><span class="fval" id="rnt-rent-val"></span></div>
            <input class="input" id="rnt-rent" type="number" min="0" max="1000000" step="1000" inputmode="numeric" value="45000" />
          </div>
          <div class="field">
            <div class="field-top"><label for="rnt-unit">The home you&rsquo;d own</label></div>
            <select class="input" id="rnt-unit"></select>
          </div>
          <div class="field">
            <div class="field-top"><label for="rnt-dp">Down payment</label><span class="fval" id="rnt-dp-val"></span></div>
            <input id="rnt-dp" type="range" min="10" max="20" value="15" step="1" />
          </div>
          <div class="field">
            <div class="field-top"><label for="rnt-rate">Interest rate</label><span class="fval" id="rnt-rate-val"></span></div>
            <input id="rnt-rate" type="range" min="7" max="12" value="8.5" step="0.1" />
          </div>
          <div class="field">
            <div class="field-top"><label for="rnt-ten">Loan tenure</label><span class="fval" id="rnt-ten-val"></span></div>
            <input id="rnt-ten" type="range" min="5" max="30" value="20" step="1" />
          </div>
        </div>
        <div class="emi-result">
          <span class="k" id="rnt-head">Just a little more than rent</span>
          <div class="emi-big" id="rnt-topup">₹0<small>/mo more</small></div>
          <span class="k normal" id="rnt-sub"></span>
          <div class="emi-break">
            <div class="b"><div class="bv" id="rnt-emi">₹0</div><div class="bl">Your home-loan EMI</div></div>
            <div class="b"><div class="bv" id="rnt-rent2">₹0</div><div class="bl">Rent you pay today</div></div>
            <div class="b"><div class="bv" id="rnt-dpamt">₹0</div><div class="bl">Down payment</div></div>
            <div class="b"><div class="bv" id="rnt-equity">₹0</div><div class="bl">Asset you&rsquo;d own</div></div>
          </div>
          <p class="rnt-msg" id="rnt-msg"></p>
          <p class="emi-note">Indicative only @ ₹6,999/sft base. Rent-vs-EMI is illustrative; taxes, maintenance &amp; appreciation not shown.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ ENQUIRE / DIRECT CONNECT ============ -->
<!-- NOTE: rep names + WhatsApp numbers are REAL, sourced from site.reps and
     base64-injected (anti-scrape). The sales STATS below (aggregate + per-rep)
     are still PLACEHOLDERS — confirm & replace before publishing (CLAUDE.md §7). -->
<section class="lead-sec section" id="enquire">
  <div class="wrap">
    <div class="connect-head reveal center">
      <p class="eyebrow eyebrow--center">Straight to a closer — no call-centre</p>
      <h2 class="h2">Talk to the two people who actually close&nbsp;Nivasa.</h2>
      <p class="lead">Your message lands <b>directly</b> with Bharat or Satish — our two senior sales leads. No pre-sales queue, no middleman, no &ldquo;someone will call you back.&rdquo; Just the person who gives you the real price, the real availability, and the sharpest deal.</p>
      <div class="connect-trust">
        <div class="ct"><b>₹74 Cr+*</b><span>closed at Nivasa · last 12 months</span></div>
        <div class="ct"><b>62</b><span>Nivasa homes booked</span></div>
      </div>
    </div>

    <div class="leads reveal d1" id="reps">
      {site.reps.map((rep) => (
        <article class="lead-card">
          <div class="lc-top">
            <div class={`avatar ${rep.avatar}`}>{rep.initials}</div>
            <div class="lc-id">
              <h3>{rep.name}</h3>
              <p>Senior Sales Lead</p>
              <span class="online"><i></i> Online now</span>
            </div>
          </div>
          <div class="lc-stats">
            <div><b>{rep.closed}</b><span>closed last year</span></div>
            <div><b>{rep.homes}</b><span>Nivasa homes sold</span></div>
          </div>
          <a class="btn btn--wa btn--block btn--lg" data-wa={enc(rep.wa)} data-rep={rep.name} data-wa-msg={waMessage} href="#enquire" rel="noopener" set:html={`${waSvg} WhatsApp ${rep.name}`}></a>
        </article>
      ))}
    </div>

    <form class="connect-alt reveal d2" data-leadform novalidate>
      <div class="ca-copy">
        <h3>Can&rsquo;t talk right now?</h3>
        <p>Drop your number and <b>Bharat will text you himself</b> — still no call-centre.</p>
      </div>
      <div class="ca-fields">
        <div class="form-field"><input name="name" type="text" placeholder="Your name" /><span class="form-err">Enter your name</span></div>
        <div class="form-field"><input name="phone" type="tel" placeholder="10-digit mobile" /><span class="form-err">Valid mobile please</span></div>
        <button class="btn btn--orange btn--lg" type="submit">Get a personal text</button>
      </div>
    </form>
    <div class="form-success connect-success">
      <div class="tick"><svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6"><path d="M20 6 9 17l-5-5"/></svg></div>
      <h3 style="color:var(--navy)">Done, <span data-name>there</span>!</h3>
      <p class="muted" style="margin-top:6px">Bharat will text you on WhatsApp shortly. Don&rsquo;t want to wait? Tap a green button above to message him right now.</p>
    </div>
  </div>
</section>

<!-- ============ FOOTER ============ -->
<footer class="site-footer">
  <div class="wrap">
    <div class="foot-grid">
      <div class="foot-brand">
        <img src="/assets/img/brand/nivasa-logo.png" alt="Elegant Nivasa" />
        <p style="max-width:36ch">High-rise lifestyle at Tellapur. Three towers, 526 residences and an 8-level clubhouse on a 4-acre gated community. A project by E-Infra — foundation on values.</p>
        <div class="foot-rera">RERA No. <b>P01100007243</b> · HMDA &amp; TS-RERA approved</div>
        <div class="foot-dev">
          <span>Developed by</span>
          <img src="/assets/img/brand/einfra-wordmark-dark.png" alt="E-Infra — Foundation on Values" />
        </div>
      </div>
      <div>
        <h4>Explore</h4>
        <a href="#angle">Why Nivasa</a><a href="#value">Full comparison</a><a href="#emi">EMI calculator</a><a href="#enquire">Enquire</a>
      </div>
      <div>
        <h4>Visit / Contact</h4>
        <a href="#enquire">Book a site visit</a><a href="#enquire">Get price sheet</a>
        <p style="margin-top:14px;color:rgba(255,255,255,.6);font-size:.9rem">Site address: Tellapur, Hyderabad, Telangana — near ORR Exit&nbsp;2.</p>
      </div>
    </div>
    <div class="foot-bottom">
      <span>© <span data-year>2026</span> Elegant Nivasa · E-Infra. All rights reserved.</span>
      <span><a href="/privacy">Privacy policy</a> · Campaign landing page — {adSet}</span>
    </div>
    <p class="foot-disclaimer">Disclaimer: This is a marketing landing page. Figures marked * — and all prices (from ₹6,999/sft), comparative figures, sales statistics, possession dates and images — are indicative, for representation only, and subject to change without notice. Comparison with &ldquo;other premium builders&rdquo; is illustrative of the micro-market and does not reference any specific developer. Floor areas are super built-up. Please verify all details with our authorised sales team and the RERA filing before purchase.</p>
  </div>
</footer>

<!-- ============ STICKY CTA — mobile floating card · desktop slim bar (shared site.css) ============ -->
<div class="stickybar">
  <p class="sb-msg">Talk to a closer now — <b>real price, real availability</b></p>
  <div class="sb-actions">
    <a class="sb-btn sb-enquire" href="#reps">Enquire</a>
    <button class="sb-btn sb-book" type="button" data-book>Book a site visit</button>
  </div>
</div>

<!-- ============ BOOK-A-VISIT DIALOG (opens in place for all [data-book] triggers; shared with homepage) ============ -->
<dialog class="bookdlg" id="bookDialog" aria-labelledby="bookDlgTitle">
  <div class="bookdlg-card">
    <button class="bookdlg-x" type="button" data-book-close aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
    <div class="bookdlg-head">
      <p class="eyebrow">Book a site visit</p>
      <h3 id="bookDlgTitle">Talk to a senior sales lead</h3>
      <p class="bookdlg-sub">Leave your number — we&rsquo;ll confirm a slot and share availability &amp; pricing. No call-centre, no spam.</p>
    </div>
    <form class="bookdlg-form" data-leadform novalidate>
      <div class="form-field"><input name="name" type="text" autocomplete="name" placeholder="Your name" /><span class="form-err">Enter your name</span></div>
      <div class="form-field bookdlg-phone">
        <span class="bookdlg-cc">+91</span>
        <input name="phone" type="tel" inputmode="numeric" autocomplete="tel" placeholder="10-digit mobile" />
        <span class="form-err">Valid mobile please</span>
      </div>
      <button class="btn btn--gold btn--block" type="submit">Request a callback</button>
      <p class="bookdlg-fine">By submitting you agree to be contacted about Elegant Nivasa.</p>
    </form>
    <div class="form-success">
      <div class="tick"><svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6"><path d="M20 6 9 17l-5-5"/></svg></div>
      <h3 style="color:var(--navy)">Thanks, <span data-name>there</span>!</h3>
      <p class="muted" style="margin-top:6px">A senior sales lead will call you shortly.</p>
    </div>
  </div>
</dialog>

<script is:inline src="/assets/js/site.js"></script>
</body>
</html>
