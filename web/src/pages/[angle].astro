---
// The three Sub-sites — one file, three static routes (/cost, /handover,
// /rental-yield), driven by the static comparison data.
import SubSiteLayout from "../layouts/SubSiteLayout.astro";
import ComparisonTable from "../components/ComparisonTable.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import { COMPARISON, ANGLES, type Angle } from "../data/comparison";

export function getStaticPaths() {
  return ANGLES.map((angle) => ({ params: { angle } }));
}

const { angle } = Astro.params as { angle: Angle };
const c = COMPARISON[angle];
---
<SubSiteLayout title={`${c.headline} — Elegant Nivasa, Tellapur`} description={c.sub}>
  <section class="section wrap">
    <p class="eyebrow">{c.eyebrow}</p>
    <h1 style="max-width:16ch">{c.headline}</h1>
    <p class="muted" style="max-width:60ch;font-size:1.15rem">{c.sub}</p>

    <div style="margin:2.5rem 0">
      <ComparisonTable rows={c.rows} />
      <p class="form-note" style="margin-top:.75rem">
        Comparison shown against a comparable new launch nearby. Figures indicative.
      </p>
    </div>

    <div style="max-width:460px">
      <WhatsAppButton
        message={c.waMessage}
        angle={c.slug}
        label="Get the full comparison & best quote →"
      />
      <p class="form-note" style="text-align:center;margin-top:.6rem">
        Speak directly to a senior sales lead. No call-centre.
      </p>
    </div>
  </section>
</SubSiteLayout>
