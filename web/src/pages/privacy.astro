---
// PRIVACY POLICY (DPDP Act 2023-aware). Self-contained like index.astro
// (own head/header/footer, loads site.css). Linked from every footer.
// Aligned with the canonical E-Infra policy at e-infra.in/privacy-policy
// (entity name, +91 phone, DND/communication-consent + third-party-links
// clauses), extended with this site's specifics (Clarity, Meta Pixel,
// Cloudflare/Resend, DPDP rights). Bracketed items still need the client's
// real details; have legal counsel review before relying on it.
import AnalyticsScripts from "../components/AnalyticsScripts.astro";
import GtmNoscript from "../components/GtmNoscript.astro";
import SocialMeta from "../components/SocialMeta.astro";
import { site } from "../config/site.ts";

const UPDATED = "22 June 2026";
const CONTACT = site.leadEmailTo;   // sales@e-infra.in
const PHONE_DISPLAY = "+91 90 90 366 366";
const ENTITY = "E-Infra (Elegant Infra)";
const ADDRESS = "Plot No. 32, Sy. No. 135, Brindavan Colony, Gandipet Road, Narsingi Village, Hyderabad, Telangana 500075";
const BROCHURE = "/assets/brochure/Elegant-Nivasa-Brochure.pdf";
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Privacy Policy — Elegant Nivasa</title>
<meta name="description" content="How E-Infra (Elegant Infra), developer of Elegant Nivasa, collects, uses and protects your personal data, in line with India's Digital Personal Data Protection Act, 2023." />
<SocialMeta title="Privacy Policy — Elegant Nivasa" description="How E-Infra (Elegant Infra), developer of Elegant Nivasa, collects, uses and protects your personal data, in line with India's Digital Personal Data Protection Act, 2023." />
<meta name="robots" content="noindex, nofollow" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/assets/css/site.css" />
<AnalyticsScripts />
<style>
  .legal { padding: clamp(110px, 14vw, 150px) 0 clamp(56px, 8vw, 90px); }
  .legal .wrap { max-width: 760px; }
  .legal .eyebrow { color: var(--gold); }
  .legal h1 { font-family: var(--font-display); color: var(--navy); font-size: clamp(2rem, 5vw, 2.9rem); margin: 10px 0 6px; }
  .legal .updated { color: var(--ink-soft); font-size: .92rem; margin-bottom: 36px; }
  .legal h2 { font-family: var(--font-display); color: var(--navy); font-size: clamp(1.25rem, 2.4vw, 1.5rem); margin: 38px 0 12px; }
  .legal p, .legal li { color: var(--ink-soft); line-height: 1.65; }
  .legal p { margin: 0 0 14px; }
  .legal ul { margin: 0 0 14px; padding-left: 22px; }
  .legal li { margin-bottom: 8px; }
  .legal a { color: var(--navy); font-weight: 600; text-decoration: underline; }
  .legal strong { color: var(--navy); }
  .legal .note { background: var(--cream-2); border: 1px solid var(--line); border-radius: 12px; padding: 16px 18px; font-size: .92rem; }
</style>
</head>
<body data-page="legal">
<GtmNoscript />

<header class="site-header scrolled">
  <a class="brand" href="/" aria-label="Elegant Nivasa home">
    <img src="/assets/img/brand/nivasa-logo.png" alt="Elegant Nivasa" />
  </a>
  <nav class="nav">
    <a class="btn btn--gold" href="/">Back to site</a>
  </nav>
</header>

<main class="legal">
  <div class="wrap">
    <p class="eyebrow">Legal</p>
    <h1>Privacy Policy</h1>
    <p class="updated">Last updated: {UPDATED}</p>

    <p>This Privacy Policy explains how <strong>{ENTITY}</strong> (&ldquo;E-Infra&rdquo;,
      &ldquo;we&rdquo;, &ldquo;us&rdquo;), the developer of the <strong>{site.name}</strong>
      residential project at {site.locality}, {site.city} (RERA&nbsp;No.&nbsp;{site.rera}), collects,
      uses, shares and protects your personal data when you use this website or contact us through it.
      We act as the <strong>Data Fiduciary</strong> for this data under India&rsquo;s
      <strong>Digital Personal Data Protection Act, 2023 (&ldquo;DPDP Act&rdquo;)</strong>.</p>

    <p class="note">Registered office: <strong>{ADDRESS}</strong>.</p>

    <h2>1. Information we collect</h2>
    <p><strong>Information you give us.</strong> When you request a callback / site visit through our
      &ldquo;Book a visit&rdquo; form, or ask us to email you the brochure, we collect the details you
      enter — typically your <strong>name, mobile number and/or email address</strong>, and any
      message or unit preference you share.</p>
    <p><strong>Information collected automatically.</strong> When you browse the site we may collect
      standard technical and usage data, including your IP address, device and browser type, pages
      viewed, referring links and campaign parameters (UTM / source page). We use:</p>
    <ul>
      <li><strong>Microsoft Clarity</strong> — behavioural analytics (heatmaps, scroll depth and
        anonymised session recordings) to understand how the site is used and improve it.</li>
      <li><strong>Meta Pixel</strong> — to measure and attribute the performance of our advertising
        on Instagram / Facebook (active once configured).</li>
    </ul>
    <p><strong>WhatsApp &amp; calls.</strong> If you tap a WhatsApp or call button, you connect with
      our sales team via WhatsApp or your phone network. Those conversations are governed by
      WhatsApp&rsquo;s and your carrier&rsquo;s own privacy terms.</p>

    <h2>2. How we use your data</h2>
    <ul>
      <li>To respond to your enquiry, call you back and schedule a site visit;</li>
      <li>To share availability, pricing, floor plans and the project brochure;</li>
      <li>To process any transaction you choose to enter into with us;</li>
      <li>To measure, secure, operate and improve the website and our advertising;</li>
      <li>To comply with applicable law and respond to lawful requests.</li>
    </ul>

    <h2>3. Legal basis &amp; consent</h2>
    <p>We process your contact details for the purpose for which you provide them — chiefly to be
      contacted about {site.name}. By submitting the form you consent to this contact. You may
      withdraw your consent at any time (see &ldquo;Your rights&rdquo; below); withdrawal does not
      affect processing already carried out.</p>

    <h2>4. Communication consent (calls, SMS, email, WhatsApp &amp; DND)</h2>
    <p>When you submit an enquiry or share your contact details, you expressly authorise E-Infra and
      its authorised representatives to contact you by <strong>phone call, SMS, email and/or
      WhatsApp</strong> regarding {site.name} and our related products and offers — <strong>even if
      your number is registered under the National Do-Not-Call (DND/NCPR) registry</strong>. This
      authorisation overrides such registration for the purpose of these communications. You can ask
      us to stop at any time using the contact details in Section&nbsp;12.</p>

    <h2>5. Who we share it with</h2>
    <p>We do <strong>not</strong> sell your personal data. We share it only with:</p>
    <ul>
      <li>Our authorised sales team and, in future, our customer-relationship (CRM) system, to act
        on your enquiry;</li>
      <li>Service providers who run the website on our behalf — including <strong>Cloudflare</strong>
        (hosting and database), <strong>Resend</strong> (transactional email),
        <strong>Microsoft Clarity</strong> and <strong>Meta</strong> (analytics / advertising);</li>
      <li>Authorities or advisors where required by law.</li>
    </ul>

    <h2>6. Cookies &amp; tracking</h2>
    <p>Microsoft Clarity and Meta Pixel may set cookies or similar identifiers in your browser to
      enable analytics and ad measurement. You can control or clear cookies through your browser
      settings, and opt out of interest-based ads via your Meta ad settings. We are introducing a
      cookie-consent control on this site; until then, you can decline tracking using your browser
      controls. Disabling cookies may limit some features.</p>

    <h2>7. Third-party links</h2>
    <p>Our website and communications may contain links to third-party sites (for example map,
      social-media or partner sites). We are not responsible for the privacy practices or content of
      those sites and encourage you to review their policies independently.</p>

    <h2>8. Data retention</h2>
    <p>We keep enquiry details for as long as needed to follow up and for our legitimate
      record-keeping, after which they are deleted or anonymised. Analytics data is retained per the
      respective providers&rsquo; default retention periods.</p>

    <h2>9. Security</h2>
    <p>Enquiry data is stored in a managed Cloudflare database and transmitted over encrypted (HTTPS)
      connections, with regular monitoring. While no method of transmission or storage over the
      internet is completely secure, we take reasonable technical and organisational measures to
      protect it.</p>

    <h2>10. Your rights under the DPDP Act</h2>
    <p>Subject to the Act, you may:</p>
    <ul>
      <li>access a summary of the personal data we hold about you and how we process it;</li>
      <li>request correction, completion or erasure of your personal data;</li>
      <li>withdraw your consent to further processing (including marketing communications);</li>
      <li>nominate another individual to exercise your rights in the event of death or incapacity;</li>
      <li>raise a grievance with us (below) and, if unresolved, with the Data Protection Board of
        India.</li>
    </ul>

    <h2>11. Children</h2>
    <p>This website and our services are intended for adults; they are not directed at children under
      18. We do not knowingly collect a child&rsquo;s personal data without verifiable parental
      consent, and will promptly delete any such data brought to our attention.</p>

    <h2>12. Grievance &amp; contact</h2>
    <p>For any privacy question, request or grievance, contact us:</p>
    <ul>
      <li>Email: <a href={`mailto:${CONTACT}`}>{CONTACT}</a></li>
      <li>Phone: <a href="tel:+919090366366">{PHONE_DISPLAY}</a></li>
      <li>Website: <a href="https://www.e-infra.in">www.e-infra.in</a></li>
      <li>Registered office: {ADDRESS}</li>
    </ul>

    <h2>13. Changes to this policy</h2>
    <p>We may update this policy from time to time. The &ldquo;Last updated&rdquo; date above shows
      when it last changed; material changes will be reflected on this page. Please review it
      periodically.</p>
  </div>
</main>

<footer class="site-footer">
  <div class="wrap">
    <div class="foot-bottom">
      <span>© <span data-year>2026</span> {site.name} · {site.developer}. All rights reserved.</span>
      <span><a href="/" style="color:inherit">Home</a> · <a href={BROCHURE} download style="color:inherit">Brochure</a></span>
    </div>
    <p class="foot-disclaimer">RERA No. {site.rera} · HMDA &amp; TS-RERA approved. This is a marketing
      website; all figures and images are indicative and subject to change. Please verify details with
      our authorised sales team and the RERA filing before purchase.</p>
  </div>
</footer>

<script is:inline src="/assets/js/site.js"></script>
</body>
</html>
