---
import SubSiteLayout from "../layouts/SubSiteLayout.astro";
---
<SubSiteLayout
  title="Elegant Nivasa, Tellapur — Same Address. Lighter Cheque. | 3 BHK from ₹6,999/sft"
  description="Premium 2 & 3 BHK homes at Tellapur, Hyderabad from ₹6,999/sft. The same Tellapur address for up to ₹20.6L less. 3 towers · 23 floors · 526 homes on 4 acres. HMDA & RERA approved."
  page="cost"
  adSet="Ad Set 01 (Cost)"
  active="cost"
>
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <p class="eyebrow hero-eyebrow stagger s1">The cost question · Tellapur</p>
        <h1 class="display stagger s2">Same Tellapur.<br>A <em>lighter</em> cheque.</h1>
        <p class="lead stagger s3">For the very same 1,375 sft on the same side of Hyderabad, other premium builders are asking up to <b>₹20.6 lakh more</b>. Elegant Nivasa starts at just <b>₹6,999 / sft</b> — three towers of refined high-rise living at Tellapur.</p>
        <div class="hero-cta stagger s4">
          <a class="btn btn--lg" href="#enquire">Get the price sheet <span class="arr">→</span></a>
          <a class="btn btn--ghost btn--lg" href="#value">See the difference</a>
        </div>
        <div class="hero-rera stagger s5">
          <span><b>HMDA &amp; RERA approved</b></span>
          <span>RERA&nbsp;No.&nbsp;<b>P01100007243</b></span>
          <span>A project by <b>E-Infra</b></span>
        </div>
      </div>
      <div class="hero-figure stagger">
        <div class="frame"><img src="/assets/img/renders/render-21.png" alt="Elegant Nivasa twin towers at dusk" fetchpriority="high" /></div>
        <div class="hero-badge tl"><span class="k">Starting</span><span class="v">₹6,999<small style="font-size:.9rem">/sft</small></span></div>
        <div class="hero-badge br"><span class="k">You could save</span><span class="v">₹20.6 L</span></div>
      </div>
    </div>
    <div class="wrap">
      <div class="ribbon reveal">
        <div class="cell"><div class="num"><span data-count="3">3</span></div><div class="lab">Towers · 23 floors each</div></div>
        <div class="cell"><div class="num"><span data-count="526">526</span></div><div class="lab">2 &amp; 3 BHK residences</div></div>
        <div class="cell"><div class="num"><span data-count="4">4</span>-Acre</div><div class="lab">Gated community</div></div>
        <div class="cell"><div class="num">5-Level</div><div class="lab">Exclusive clubhouse</div></div>
      </div>
    </div>
  </section>
</SubSiteLayout>
