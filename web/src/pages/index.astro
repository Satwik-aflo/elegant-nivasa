---
// MAIN SITE (homepage). Product/desire-first single-scroll page: hero ·
// gallery · corridor test · car-free podium · location · possession/trust ·
// floor plans · brochure + Lead form. Styled to match the three sub-sites.
import AnalyticsScripts from "../components/AnalyticsScripts.astro";
import GtmNoscript from "../components/GtmNoscript.astro";
import SocialMeta from "../components/SocialMeta.astro";
import Scoreboard from "../components/Scoreboard.astro";

// Floor-plan plates (open — no gating). Config/saleable/facing read off each
// plate; site.js wires the [data-gallery] lightbox.
const plans = [
  { n: 1, bhk: "3 BHK", sft: "1,700", face: "East" },
  { n: 2, bhk: "3 BHK", sft: "1,380", face: "West" },
  { n: 3, bhk: "3 BHK", sft: "2,206", face: "West" },
  { n: 4, bhk: "3 BHK", sft: "1,830", face: "West" },
  { n: 5, bhk: "2 BHK", sft: "1,372", face: "North" },
  { n: 6, bhk: "3 BHK", sft: "1,830", face: "East" },
].map((p) => ({
  ...p,
  img: `/assets/img/floorplans/type-${p.n}.png`,
  alt: `Elegant Nivasa floor plan — ${p.bhk}, ${p.sft} sft, ${p.face} facing`,
}));

// Render gallery — asymmetric grid; wide/tall classes drive the layout.
const gallery = [
  { n: 2, cls: "wide" }, { n: 6, cls: "tall" }, { n: 3, cls: "" },
  { n: 7, cls: "" }, { n: 9, cls: "wide" }, { n: 11, cls: "" },
  { n: 12, cls: "" }, { n: 4, cls: "tall" }, { n: 8, cls: "wide" },
  { n: 10, cls: "" },
].map((g) => ({ ...g, img: `/assets/img/renders/render-${g.n}.jpg` }));

// Amenities — the 8-level / 40,000+ sft clubhouse + outdoor amenities
// (source: live site / Brochure.pdf). Static, zero-JS; each group renders a
// chip cloud under a sub-heading.
const clubAmenities = [
  "Infinity pool", "Gym", "CrossFit", "Badminton", "Squash", "Yoga studio",
  "Spa", "Banquet hall", "Business lounge", "Crèche",
  "Library & indoor games", "Guest rooms", "Café & supermarket",
];
const outdoorAmenities = [
  "Landscaped parks", "Jogging track", "Tennis court", "Cricket net",
  "Half basketball", "Skating rink", "Outdoor gym", "Senior seating",
  "EV charging",
];

// Brochure: free, ungated download (soft WhatsApp capture is optional).
const BROCHURE = "/assets/brochure/Elegant-Nivasa-Brochure.pdf";
const PHONE = "9090366366"; // public sales line (shown on the live site)

// Hero = full-bleed cinematic (variant B, chosen 2026-06-21). On mobile the
// stat chips get a solid dark fill so the text reads over the render.
const HERO_LEAD = "526 residences across four acres in Tellapur, wrapped around an <b>8-level, 40,000+ sft clubhouse</b>. Spacious 2 &amp; 3 BHK homes from <b>₹6,999/sft</b>*, ready June 2027.";
const HERO_IMG = "/assets/img/renders/hero-ai.webp";
const EINFRA_DARK = "/assets/img/brand/einfra-wordmark-dark.png";
const PAGE_TITLE = "Elegant Nivasa, Tellapur — Room to Live Well | Premium 2 & 3 BHK";
const PAGE_DESC = "Premium 2 & 3 BHK homes at Tellapur, West Hyderabad — three towers, 526 residences and a clubhouse on a 4-acre car-free podium community, two minutes from the ORR. For about ₹20 lakhs less than the branded launch next door. HMDA & RERA approved.";
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{PAGE_TITLE}</title>
<meta name="description" content={PAGE_DESC} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/assets/css/site.css" />
<link rel="stylesheet" href="/assets/css/proto.css" />
<SocialMeta title={PAGE_TITLE} description={PAGE_DESC} />
<AnalyticsScripts />
</head>
<body data-page="home">
<GtmNoscript />

<!-- ============ HEADER ============ -->
<header class="site-header">
  <a class="brand" href="/" aria-label="Elegant Nivasa home">
    <img src="/assets/img/brand/nivasa-logo.png" alt="Elegant Nivasa" />
  </a>
  <button class="nav-toggle" aria-label="Menu" aria-expanded="false"><span></span><span></span><span></span></button>
  <nav class="nav">
    <a href="#value">Compare</a>
    <a href="#gallery">Gallery</a>
    <a href="#corridor">The corridor</a>
    <a href="#amenities">Amenities</a>
    <a href="#plans">Floor plans</a>
    <a href="#location">Location</a>
    <a class="btn btn--gold" href={`tel:${PHONE}`} data-book>Book a visit</a>
  </nav>
</header>

<!-- ============ HERO — stacked: full render in a top frame, copy panel below ============ -->
<section class="hero hero--bleed">
  <div class="hb-stage">
    <img class="hb-bg" src={HERO_IMG} alt="Elegant Nivasa towers at Tellapur" fetchpriority="high" />
    <div class="hb-scrim"></div>
    <div class="wrap hb-inner">
      <p class="eyebrow stagger s1">Tellapur · West Hyderabad</p>
      <h1 class="display stagger s2">A home, and a <em>world</em> around it.</h1>
      <p class="lead stagger s3" set:html={HERO_LEAD}></p>
      <div class="hero-cta stagger s4">
        <a class="btn btn--gold btn--lg" href={`tel:${PHONE}`} data-book>Book a visit</a>
        <a class="btn btn--ghost btn--lg" href={BROCHURE} download data-brochure>Download brochure</a>
      </div>
      <div class="hero-rera stagger s5">
        <span><b>HMDA &amp; RERA approved</b></span>
        <span>RERA&nbsp;No.&nbsp;<b>P01100007243</b></span>
      </div>
    </div>
    <div class="hd-figbadge"><span>A project by</span><img src={EINFRA_DARK} alt="E-Infra — Foundation on Values" /></div>
  </div>

  <div class="wrap">
    <div class="ribbon reveal">
      <div class="cell"><div class="num"><span data-count="3">3</span></div><div class="lab">Towers · 23 floors each</div></div>
      <div class="cell"><div class="num"><span data-count="526">526</span></div><div class="lab">2 &amp; 3 BHK residences</div></div>
      <div class="cell"><div class="num"><span data-count="4">4</span>-Acre</div><div class="lab">Gated community</div></div>
      <div class="cell"><div class="num">8-Level</div><div class="lab">40,000+ sft clubhouse</div></div>
    </div>
  </div>
</section>

<!-- ============ COMPARISON SCOREBOARD — reused sub-site table, up front ============ -->
<Scoreboard />

<!-- ============ GALLERY — the project, up front ============ -->
<section class="section gallery" id="gallery">
  <div class="wrap">
    <div class="shead reveal center">
      <p class="eyebrow eyebrow--center">A look around</p>
      <h2 class="h2">Picture your mornings here.</h2>
      <p class="lead" style="margin-inline:auto">Elevations, the podium deck, the clubhouse and the landscaped greens. Tap any image to enlarge.</p>
    </div>
    <div class="g-grid" data-gallery>
      {gallery.map((g) => (
        <figure class={`g-item ${g.cls}`}>
          <img src={g.img} alt="Elegant Nivasa render" loading="lazy" />
        </figure>
      ))}
    </div>
  </div>
</section>

<!-- ============ THE CORRIDOR TEST — intro band ============ -->
<section class="section corridor-intro" id="corridor">
  <div class="wrap center">
    <div class="shead reveal">
      <p class="eyebrow eyebrow--center">The difference you can feel</p>
      <h2 class="h2">The corridor test</h2>
      <p class="lead" style="margin-inline:auto">Same cheque, very different hallway. Scroll — and watch a cramped <b>6′6″</b> corridor open out to the Nivasa <b>14&nbsp;ft</b>.</p>
    </div>
  </div>
</section>

<!-- ============ THE CORRIDOR TEST — scroll animation ============ -->
<section class="ct" data-corridor data-open="0">
  <div class="ct-track" data-track>
    <div class="ct-stage">
      <div class="ct-bg"></div>
      <div class="wall l"></div>
      <div class="wall r"></div>
      <div class="ct-logo" data-logo><img src="/assets/img/brand/nivasa-logo.png" alt="Elegant Nivasa" /></div>
      <div class="ct-num" data-num>6′6″</div>
      <p class="ct-eyebrow">keep scrolling</p>
      <div class="ct-scrim"></div>
      <div class="ct-hud">
        <p class="tag" data-tag>A typical branded-builder corridor</p>
        <p class="msg" data-msg>Two people pass shoulder-to-shoulder. A shoe rack, and the hallway is blocked.</p>
      </div>
      <div class="ct-bar"><span data-bar></span></div>
    </div>
  </div>
</section>

<!-- ============ THE CAR-FREE PODIUM — safe haven ============ -->
<section class="section value podium" id="podium">
  <div class="wrap value-inner">
    <div class="shead center reveal">
      <p class="eyebrow eyebrow--center">The safe haven we built on purpose</p>
      <p class="podium-num">0</p>
      <h2 class="h2">cars on the podium. <em class="podium-ever">Ever.</em></h2>
      <p class="lead" style="margin-inline:auto">Every vehicle parks <b>below</b> the deck — so the only thing moving across the podium is people. Your children walk to the play area without watching for traffic.</p>
    </div>
    <div class="podium-stats reveal">
      <div class="ps-cell"><span class="ps-n">100%</span><span class="ps-l">of the podium is pedestrian-only</span></div>
      <div class="ps-cell"><span class="ps-n">~1,100</span><span class="ps-l">parking spaces, across 5 levels below the deck</span></div>
      <div class="ps-cell"><span class="ps-n">4 acres</span><span class="ps-l">to roam, without watching for a car</span></div>
    </div>
  </div>
</section>

<!-- ============ AMENITIES — 8-level clubhouse + outdoors ============ -->
<!-- ============ AMENITIES — 8-level clubhouse + outdoor (render-14 feature) ============ -->
<section class="section am" id="amenities">
  <div class="wrap am-feature">
    <div class="am-feature-img reveal" style="background-image:url(/assets/img/renders/render-14.jpg)" role="img" aria-label="Club @ Nivasa — the 8-level clubhouse">
      <div class="am-figbadge">
        <span><b>8</b> levels</span><span><b>40,000+</b> sft</span><span><b>4</b> acres</span>
      </div>
    </div>
    <div class="am-feature-panel reveal d1">
      <p class="eyebrow">Room to do everything</p>
      <h2 class="h2">An <em>8-level</em> clubhouse, and four acres around it.</h2>
      <p class="lead">Over <b>40,000 sft</b> of indoor clubhouse, wrapped by a car-free podium of parks, courts and tracks — so the day-to-day, from a morning swim to the kids&rsquo; evening play, never leaves home.</p>
      <div class="am-grid">
        <div class="am-group">
          <h3 class="am-gh"><span class="am-gh-k">Indoors</span>The 8-level clubhouse</h3>
          <ul class="am-chips">
            {clubAmenities.map((a) => <li class="am-chip">{a}</li>)}
          </ul>
        </div>
        <div class="am-group">
          <h3 class="am-gh"><span class="am-gh-k">Outdoors</span>Across the podium &amp; grounds</h3>
          <ul class="am-chips">
            {outdoorAmenities.map((a) => <li class="am-chip am-chip--out">{a}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ LOCATION & CONNECTIVITY ============ -->
<section class="section connect" id="location">
  <div class="wrap">
    <div class="shead reveal center">
      <p class="eyebrow eyebrow--center">Where it sits</p>
      <h2 class="h2">Two minutes to the ORR.<br><em>The whole city follows.</em></h2>
      <p class="lead" style="margin-inline:auto">Tellapur, West Hyderabad — off a 100&nbsp;ft masterplan road, a two-minute drive from ORR Exit&nbsp;2. The Financial District, Gachibowli and the airport are all an easy run from your door.</p>
    </div>
    <div class="loc-grid">
      <div class="cmap">
        <svg data-citymap viewBox="0 0 760 600" role="img" aria-label="Map of drive times from Elegant Nivasa, Tellapur"></svg>
        <p class="cmap-cap">Marker positions to true bearing &amp; scale (OpenStreetMap data); ORR&nbsp;Exit&nbsp;2 location indicative.</p>
      </div>
      <iframe class="loc-iframe" title="Elegant Nivasa on Google Maps" loading="lazy" allowfullscreen
        referrerpolicy="no-referrer-when-downgrade"
        src="https://www.google.com/maps?q=E-infra+Elegant+Nivasa,+Tellapur&z=16&output=embed"></iframe>
    </div>
    <p class="conn-note reveal">Access via a <b>100&nbsp;ft masterplan road</b> — no narrow approach, no bottleneck at the gate.</p>
  </div>
</section>

<!-- ============ POSSESSION / TRUST strip ============ -->
<section class="section trust trust--big">
  <div class="wrap tg-grid">
    <div class="tg-figure reveal">
      <div class="tg-ring" style="--p:78">
        <span class="tg-pct">78<small>%</small></span>
        <span class="tg-cap">structure complete</span>
      </div>
    </div>
    <div class="tg-copy reveal d1">
      <p class="eyebrow">On time, on record</p>
      <h2>Not a launch render.<br>A building you can <em>visit.</em><br>Now find your floor.</h2>
      <p>Possession is near and the structure is well underway. Study the floor plans just below, then come walk those very floors in person.</p>
      <div class="tg-meta">
        <div><b>2027</b><span>Possession</span></div>
        <div><b>RERA</b><span>P01100007243</span></div>
        <div><b>HMDA</b><span>&amp; TS-RERA approved</span></div>
      </div>
      <a class="btn btn--gold tg-brochure" href={BROCHURE} download data-brochure>See it all in the brochure</a>
    </div>
  </div>
</section>

<!-- ============ FLOOR PLANS (open · no gate) ============ -->
<section class="section plans" id="plans">
  <div class="wrap">
    <div class="shead reveal center">
      <p class="eyebrow eyebrow--center">Floor plans</p>
      <h2 class="h2">Six thoughtful configurations.</h2>
      <p class="lead" style="margin-inline:auto">2 &amp; 3 BHK homes, 1,372&ndash;2,206 sft saleable. Tap any plate to enlarge &mdash; open to view, no form, no gate.</p>
    </div>
    <div class="fp-grid" data-gallery>
      {plans.map((p) => (
        <figure class="fp-card">
          <img src={p.img} alt={p.alt} loading="lazy" />
          <figcaption>
            <span class="fp-meta"><b>{p.bhk} &middot; {p.sft} sft</b><span class="fp-face">{p.face} facing</span></span>
            <span class="fp-zoom" aria-hidden="true">&#10530; Enlarge</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<!-- ============ EMI / AFFORDABILITY CALCULATOR (ported from sub-sites; site.js wires [data-calc]) ============ -->
<section class="section" id="emi">
  <div class="wrap">
    <div class="shead reveal center">
      <p class="eyebrow eyebrow--center">Plan your home</p>
      <h2 class="h2">See the home your income unlocks.</h2>
      <p class="lead" style="margin-inline:auto">Two quick tools — find the Nivasa home your income qualifies for, or see how little more than your rent it takes to own one.</p>
    </div>
    <div class="calc reveal d1" data-calc>
      <div class="calc-tabs" role="tablist">
        <button type="button" class="calc-tab active" data-mode="afford">Calculate it yourself</button>
        <button type="button" class="calc-tab" data-mode="rent">Already paying rent?</button>
      </div>

      <!-- AFFORDABILITY -->
      <div class="emi calc-panel" data-panel="afford">
        <div class="emi-controls">
          <div class="field">
            <div class="field-top"><label for="aff-income">Your monthly income</label><span class="fval" id="aff-income-val"></span></div>
            <input class="input" id="aff-income" type="number" min="0" max="10000000" step="5000" inputmode="numeric" value="200000" />
          </div>
          <label class="check" for="aff-co"><input type="checkbox" id="aff-co" /> Add another earning family member</label>
          <div class="field co-field" id="aff-co-wrap" hidden>
            <div class="field-top"><label for="aff-co-income">Co-applicant monthly income</label><span class="fval" id="aff-co-val"></span></div>
            <input class="input" id="aff-co-income" type="number" min="0" max="10000000" step="5000" inputmode="numeric" value="100000" />
          </div>
          <div class="field">
            <div class="field-top"><label for="aff-existing">Existing EMIs / obligations</label><span class="fval" id="aff-emi-val"></span></div>
            <input class="input" id="aff-existing" type="number" min="0" max="1000000" step="1000" inputmode="numeric" value="0" />
          </div>
          <div class="field">
            <div class="field-top"><label for="aff-foir">EMI from income</label><span class="fval" id="aff-foir-val"></span></div>
            <input id="aff-foir" type="range" min="40" max="50" value="45" step="1" />
          </div>
          <div class="field">
            <div class="field-top"><label for="aff-rate">Interest rate</label><span class="fval" id="aff-rate-val"></span></div>
            <input id="aff-rate" type="range" min="7" max="12" value="8.5" step="0.1" />
          </div>
          <div class="field">
            <div class="field-top"><label for="aff-ten">Loan tenure</label><span class="fval" id="aff-ten-val"></span></div>
            <input id="aff-ten" type="range" min="5" max="30" value="20" step="1" />
          </div>
          <div class="field">
            <div class="field-top"><label for="aff-dp">Down payment</label><span class="fval" id="aff-dp-val"></span></div>
            <input id="aff-dp" type="range" min="10" max="40" value="20" step="1" />
          </div>
        </div>
        <div class="emi-result">
          <span class="k">You could be eligible for</span>
          <div class="emi-big" id="aff-loan">₹0</div>
          <span class="k normal">home loan · on a <span id="aff-budget">₹0</span> total budget</span>
          <div class="emi-break">
            <div class="b"><div class="bv" id="aff-maxemi">₹0</div><div class="bl">Monthly EMI you can service</div></div>
            <div class="b"><div class="bv" id="aff-dpamt">₹0</div><div class="bl">Down payment needed</div></div>
            <div class="b"><div class="bv" id="aff-area">0 sft</div><div class="bl">Affordable size</div></div>
            <div class="b"><div class="bv" id="aff-income-tot">₹0</div><div class="bl">Income considered</div></div>
          </div>
          <div class="aff-fit" id="aff-fit"></div>
          <p class="emi-note">Indicative eligibility at 40–50% of income toward EMI (bank FOIR). Final sanction depends on your lender, profile &amp; documents.</p>
        </div>
      </div>

      <!-- RENT VS OWN -->
      <div class="emi calc-panel" data-panel="rent" hidden>
        <div class="emi-controls">
          <div class="field">
            <div class="field-top"><label for="rnt-rent">Rent you pay now</label><span class="fval" id="rnt-rent-val"></span></div>
            <input class="input" id="rnt-rent" type="number" min="0" max="1000000" step="1000" inputmode="numeric" value="45000" />
          </div>
          <div class="field">
            <div class="field-top"><label for="rnt-unit">The home you&rsquo;d own</label></div>
            <select class="input" id="rnt-unit"></select>
          </div>
          <div class="field">
            <div class="field-top"><label for="rnt-dp">Down payment</label><span class="fval" id="rnt-dp-val"></span></div>
            <input id="rnt-dp" type="range" min="10" max="20" value="15" step="1" />
          </div>
          <div class="field">
            <div class="field-top"><label for="rnt-rate">Interest rate</label><span class="fval" id="rnt-rate-val"></span></div>
            <input id="rnt-rate" type="range" min="7" max="12" value="8.5" step="0.1" />
          </div>
          <div class="field">
            <div class="field-top"><label for="rnt-ten">Loan tenure</label><span class="fval" id="rnt-ten-val"></span></div>
            <input id="rnt-ten" type="range" min="5" max="30" value="20" step="1" />
          </div>
        </div>
        <div class="emi-result">
          <span class="k" id="rnt-head">Just a little more than rent</span>
          <div class="emi-big" id="rnt-topup">₹0<small>/mo more</small></div>
          <span class="k normal" id="rnt-sub"></span>
          <div class="emi-break">
            <div class="b"><div class="bv" id="rnt-emi">₹0</div><div class="bl">Your home-loan EMI</div></div>
            <div class="b"><div class="bv" id="rnt-rent2">₹0</div><div class="bl">Rent you pay today</div></div>
            <div class="b"><div class="bv" id="rnt-dpamt">₹0</div><div class="bl">Down payment</div></div>
            <div class="b"><div class="bv" id="rnt-equity">₹0</div><div class="bl">Asset you&rsquo;d own</div></div>
          </div>
          <p class="rnt-msg" id="rnt-msg"></p>
          <p class="emi-note">Indicative only @ ₹6,999/sft base. Rent-vs-EMI is illustrative; taxes, maintenance &amp; appreciation not shown.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ CONFIDENCE CROSS-SELL — on-page entry to the 3 sub-sites (below EMI) ============ -->
<section class="section xs" id="compare">
  <div class="wrap">
    <div class="shead reveal center">
      <p class="eyebrow eyebrow--center">Still weighing it up?</p>
      <h2 class="h2">See us <em>head-to-head</em> with the launch next door.</h2>
    </div>
    <div class="xs-grid">
      <a class="xs-card reveal" href="/cost">
        <span class="xs-fig">₹20.6&nbsp;L<small>* less</small></span>
        <span class="xs-body"><span class="xs-k">Cost</span><span class="xs-h">Pay less per sft</span></span>
        <span class="xs-go">→</span>
      </a>
      <a class="xs-card reveal d1" href="/handover">
        <span class="xs-fig">2027<small>not 2031</small></span>
        <span class="xs-body"><span class="xs-k">Handover</span><span class="xs-h">Move in years sooner</span></span>
        <span class="xs-go">→</span>
      </a>
      <a class="xs-card reveal d2" href="/rental-yield">
        <span class="xs-fig">₹16.8&nbsp;L<small>* rent</small></span>
        <span class="xs-body"><span class="xs-k">Rental yield</span><span class="xs-h">Earn while they wait</span></span>
        <span class="xs-go">→</span>
      </a>
    </div>
  </div>
</section>

<!-- ============ FOOTER ============ -->
<footer class="site-footer">
  <div class="wrap">
    <div class="foot-grid">
      <div class="foot-brand">
        <img src="/assets/img/brand/nivasa-logo.png" alt="Elegant Nivasa" />
        <p style="max-width:36ch">High-rise lifestyle at Tellapur. Three towers, 526 residences and an 8-level clubhouse on a 4-acre gated community.</p>
        <div class="foot-rera">RERA No. <b>P01100007243</b> · HMDA &amp; TS-RERA approved</div>
        <div class="foot-dev">
          <span>Developed by</span>
          <img src="/assets/img/brand/einfra-wordmark-dark.png" alt="E-Infra — Foundation on Values" />
        </div>
      </div>
      <div>
        <h4>Explore</h4>
