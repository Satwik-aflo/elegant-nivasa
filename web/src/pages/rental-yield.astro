---
import SubSiteLayout from "../layouts/SubSiteLayout.astro";
---
<SubSiteLayout
  title="Elegant Nivasa, Tellapur — Cashflow Starts With Possession | Earn ₹16.8L Sooner"
  description="Own at Tellapur and your asset starts earning from 2028 — a potential ₹16.8L of rental income others miss by waiting. Premium 2 & 3 BHK from ₹6,999/sft. HMDA & RERA approved."
  page="yield"
  adSet="Ad Set 02 (Rental Yield)"
  active="rental-yield"
>
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <p class="eyebrow hero-eyebrow stagger s1">The yield question · Tellapur</p>
        <h1 class="display stagger s2">Cashflow starts<br>with <em>possession</em>.</h1>
        <p class="lead stagger s3">Every year you wait is a year of rent you never collect. Own at Elegant Nivasa and your asset starts earning from <b>2028</b> — a potential <b>₹16.8 lakh</b> of rental income that others lose simply by buying later.</p>
        <div class="hero-cta stagger s4">
          <a class="btn btn--lg" href="#enquire">Start earning sooner <span class="arr">→</span></a>
          <a class="btn btn--ghost btn--lg" href="#value">See the yield timeline</a>
        </div>
        <div class="hero-rera stagger s5">
          <span><b>HMDA &amp; RERA approved</b></span>
          <span>RERA&nbsp;No.&nbsp;<b>P01100007243</b></span>
          <span>A project by <b>E-Infra</b></span>
        </div>
      </div>
      <div class="hero-figure stagger">
        <div class="frame"><img src="/assets/img/renders/render-16.jpg" alt="Elegant Nivasa towers lit at night" fetchpriority="high" /></div>
        <div class="hero-badge tl"><span class="k">Rent starts</span><span class="v">2028</span></div>
        <div class="hero-badge br"><span class="k">Income you&rsquo;d miss</span><span class="v">₹16.8 L</span></div>
      </div>
    </div>
    <div class="wrap">
      <div class="ribbon reveal">
        <div class="cell"><div class="num"><span data-count="3">3</span></div><div class="lab">Towers · 23 floors each</div></div>
        <div class="cell"><div class="num"><span data-count="526">526</span></div><div class="lab">2 &amp; 3 BHK residences</div></div>
        <div class="cell"><div class="num"><span data-count="4">4</span>-Acre</div><div class="lab">Gated community</div></div>
        <div class="cell"><div class="num">5-Level</div><div class="lab">Exclusive clubhouse</div></div>
      </div>
    </div>
  </section>
</SubSiteLayout>
