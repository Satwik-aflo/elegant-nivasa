---
import SubSiteLayout from "../layouts/SubSiteLayout.astro";
import { ANGLES } from "../data/comparison.ts";
const h = ANGLES.handover.hero;
---
<SubSiteLayout
  title="Elegant Nivasa, Tellapur — Possession June 2027 | When Does the Asset Start Working?"
  description="Possession June 2027, already 78% structure-complete — years ahead of comparable launches. Earlier possession, earlier returns. Premium 2 & 3 BHK from ₹6,999/sft at Tellapur. HMDA & RERA approved."
  angle="handover"
  adSet="Ad Set 03 (Handover)"
>
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <p class="eyebrow hero-eyebrow stagger s1">{h.eyebrow}</p>
        <h1 class="display stagger s2" set:html={h.headline}></h1>
        <p class="lead stagger s3" set:html={h.lead}></p>
        <div class="hero-cta stagger s4">
          <a class="btn btn--lg" href="#enquire">{h.ctaPrimary} <span class="arr">→</span></a>
          <a class="btn btn--ghost btn--lg" href="#value">{h.ctaSecondary}</a>
        </div>
        <div class="hero-rera stagger s5">
          <span><b>HMDA &amp; RERA approved</b></span>
          <span>RERA&nbsp;No.&nbsp;<b>P01100007243</b></span>
          <span>A project by <b>E-Infra</b></span>
        </div>
      </div>
      <div class="hero-figure stagger">
        <div class="frame"><img src="/assets/img/renders/render-7.jpg" alt="Elegant Nivasa towers nearing completion" fetchpriority="high" /></div>
        {h.badges.map((b) => (
          <div class={`hero-badge ${b.pos}`}><span class="k">{b.k}</span><span class="v" set:html={b.v}></span></div>
        ))}
      </div>
    </div>
    <div class="wrap">
      <div class="ribbon reveal">
        <div class="cell"><div class="num"><span data-count="3">3</span></div><div class="lab">Towers · 23 floors each</div></div>
        <div class="cell"><div class="num"><span data-count="526">526</span></div><div class="lab">2 &amp; 3 BHK residences</div></div>
        <div class="cell"><div class="num"><span data-count="4">4</span>-Acre</div><div class="lab">Gated community</div></div>
        <div class="cell"><div class="num">8-Level</div><div class="lab">40,000+ sft clubhouse</div></div>
      </div>
    </div>
  </section>
</SubSiteLayout>
