---
// Loads Clarity + Meta Pixel only when ids are set in config (empty = off, safe
// for dev). Consent gating deferred — see CLAUDE.md §8.
import { site } from "../config/site";
const { clarityId, metaPixelId, googleAdsId } = site.analytics;
---
{clarityId && (
  <script is:inline define:vars={{ clarityId }}>
    (function (c, l, a, r, i, t, y) {
      c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
      t = l.createElement(r); t.async = 1; t.src = "https://www.clarity.ms/tag/" + i;
      y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
    })(window, document, "clarity", "script", clarityId);
  </script>
)}

{metaPixelId && (
  <script is:inline define:vars={{ metaPixelId }}>
    !function (f, b, e, v, n, t, s) {
      if (f.fbq) return; n = f.fbq = function () { n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments); };
      if (!f._fbq) f._fbq = n; n.push = n; n.loaded = !0; n.version = "2.0"; n.queue = [];
      t = b.createElement(e); t.async = !0; t.src = v; s = b.getElementsByTagName(e)[0]; s.parentNode.insertBefore(t, s);
    }(window, document, "script", "https://connect.facebook.net/en_US/fbevents.js");
    fbq("init", metaPixelId); fbq("track", "PageView");
  </script>
)}

{googleAdsId && (
  <script is:inline define:vars={{ googleAdsId }}>
    (function (d, s, id) {
      var t = d.createElement(s); t.async = 1;
      t.src = "https://www.googletagmanager.com/gtag/js?id=" + id;
      var f = d.getElementsByTagName(s)[0]; f.parentNode.insertBefore(t, f);
    })(document, "script", googleAdsId);
    window.dataLayer = window.dataLayer || [];
    window.gtag = function () { window.dataLayer.push(arguments); };
    gtag("js", new Date());
    // Enables auto-tagging — captures the gclid so conversions attribute to the keyword.
    gtag("config", googleAdsId);
  </script>
)}

<!-- exposes window.track() for inline event calls -->
<script>
  import "../lib/analytics.ts";
</script>
