---
// Sub-site CTA. Round-robins across the two Sales rep numbers and fires a
// whatsapp_click Conversion. Numbers are base64'd in the markup (anti-scrape)
// and decoded client-side, so bots can't harvest raw wa.me links from source.
import { site } from "../config/site";
interface Props { message: string; angle: string; label?: string; }
const { message, angle, label = "Chat on WhatsApp" } = Astro.props;
const repsB64 = Buffer.from(JSON.stringify(site.reps.map((r) => r.wa))).toString("base64");
---
<a
  class="btn btn--wa btn--lg btn--block"
  data-wa
  data-reps={repsB64}
  data-msg={message}
  data-angle={angle}
  href="#"
  target="_blank"
  rel="noopener nofollow"
>{label}</a>

<script>
  document.querySelectorAll<HTMLAnchorElement>("a[data-wa]").forEach((a) => {
    let nums: string[] = [];
    try { nums = JSON.parse(atob(a.dataset.reps || "")); } catch {}
    if (nums.length) {
      const num = nums[Math.floor(Math.random() * nums.length)]; // round-robin
      const msg = (a.dataset.msg || "").replaceAll("{rep}", "team");
      a.href = "https://wa.me/" + num + "?text=" + encodeURIComponent(msg);
    }
    a.addEventListener("click", () => {
      (window as any).track?.("whatsapp_click", { angle: a.dataset.angle });
    });
  });
</script>
