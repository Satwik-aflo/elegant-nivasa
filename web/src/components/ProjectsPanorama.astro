---
// "E-Infra is building across the city" — the masterplan flythrough video with clickable project
// hotspots pinned over it, shown on both thank-you pages for cross-project confidence. Map-legend
// pattern (chosen by prototype, 2026-06-26): each hotspot is a numbered gold pin; the legend below
// repeats the numbers + names so the dots are identifiable on mobile (no room for always-on tags).
// Desktop also reveals the name on hover. Classes `enp-`. Only client JS is a project_click ping.
// Spec: docs/specs/2026-06-25-projects-panorama-thankyou.md
interface Project { label: string; left: number; top: number; href?: string; home?: boolean; }
// left/top = % position of the dot's centre over the video (picked via the hotspot picker tool).
// Elegant Nivasa → home. Celosia now live (celosiavillas.com, 2026-06-26).
const PROJECTS: Project[] = [
  { label: "Moonglade",      left: 20.8, top: 71.5, href: "https://beseen.moonglade.life/" },
  { label: "Elegant Nivasa", left: 41.3, top: 56.2, href: "/", home: true },
  { label: "One Downtown",   left: 58.9, top: 65.1, href: "https://onedowntown.in/" },
  { label: "Skyven",         left: 67.1, top: 34.5, href: "https://www.theskyven.com" },
  { label: "La Casa",        left: 72.1, top: 78.0, href: "https://lacasavilla.in/" },
  { label: "Celosia",        left: 89.5, top: 78.4, href: "https://celosiavillas.com/" },
];
const VIDEO  = "/assets/video/einfra-masterplan.mp4";
const POSTER = "/assets/img/renders/einfra-masterplan-poster.jpg";
const pos = (p: Project) => `left:${p.left}%;top:${p.top}%`;
---
<section class="enp" id="projects">
  <p class="enp-eyebrow">Not just one address</p>
  <h2 class="enp-h2">E-Infra is building across the city.</h2>

  <div class="enp-pano">
    <video class="enp-video" muted loop playsinline preload="metadata"
      poster={POSTER} width="960" height="540"
      aria-label="E-Infra masterplan — developments rising across the city">
      <source src={VIDEO} type="video/mp4" />
    </video>
    {PROJECTS.map((p, i) => (
      <a class="enp-hot" href={p.href} target={p.home ? undefined : "_blank"} rel={p.home ? undefined : "noopener"} data-proj={p.label} style={pos(p)} aria-label={p.label}>
        <span class="enp-name">{p.label}</span><span class="enp-num">{i + 1}</span>
      </a>
    ))}
  </div>

  <div class="enp-chips">
    {PROJECTS.map((p, i) => (
      <a class="enp-chip" href={p.href} target={p.home ? undefined : "_blank"} rel={p.home ? undefined : "noopener"} data-proj={p.label}><span class="enp-n">{i + 1}</span>{p.label}</a>
    ))}
  </div>
</section>

<style>
  .enp { width: 100%; max-width: 540px; margin-inline: auto; }
  .enp-eyebrow { color: var(--gold); font-weight: 700; letter-spacing: .14em; text-transform: uppercase; font-size: .72rem; margin: 0 0 7px; }
  .enp-h2 { font-family: var(--font-display, "Fraunces", serif); font-weight: 500; color: var(--navy); font-size: clamp(1.3rem,2.2vw,1.7rem); line-height: 1.14; margin: 0; }

  .enp-pano { position: relative; width: 100%; margin-top: 24px; }   /* margin gives top labels room */
  .enp-video { display: block; width: 100%; height: auto; border-radius: 12px; background: #eef1f8;
    box-shadow: 0 16px 40px rgba(22,32,74,.18); }

  .enp-hot { position: absolute; transform: translate(-50%, -50%); display: block; text-decoration: none; z-index: 2; }
  /* numbered gold pin — the number ties each dot to the legend below */
  .enp-num { display: grid; place-items: center; width: 24px; height: 24px; border-radius: 50%;
    background: var(--gold); color: #16204a; border: 2px solid #fff; box-shadow: 0 1px 5px rgba(0,0,0,.55);
    font-weight: 800; font-size: .78rem; font-variant-numeric: tabular-nums; transition: transform .2s; }
  .enp-hot:hover .enp-num, .enp-hot:focus-visible .enp-num { transform: scale(1.18); }
  /* name revealed on hover/focus (desktop nicety; mobile relies on the numbered legend) */
  .enp-name { position: absolute; left: 50%; bottom: calc(100% + 9px); transform: translateX(-50%);
    background: var(--gold); color: #16204a; font-weight: 700; font-size: .74rem; white-space: nowrap;
    padding: 3px 9px; border-radius: 5px; box-shadow: 0 2px 6px rgba(0,0,0,.35);
    opacity: 0; pointer-events: none; transition: opacity .2s; }
  .enp-name::after { content: ""; position: absolute; left: 50%; top: 100%; transform: translateX(-50%);
    border: 5px solid transparent; border-top-color: var(--gold); }
  .enp-hot:hover .enp-name, .enp-hot:focus-visible .enp-name { opacity: 1; }

  /* numbered legend — repeats the pin numbers + names */
  .enp-chips { display: flex; flex-wrap: wrap; gap: 9px; margin-top: 18px; }
  .enp-chip { display: inline-flex; align-items: center; gap: 9px; text-decoration: none; color: var(--navy);
    background: #fff; border: 1px solid var(--line); border-radius: 999px; padding: 7px 15px 7px 7px; font-weight: 600;
    font-size: .9rem; transition: background .2s, border-color .2s; }
  .enp-chip:hover { background: var(--cream-2); border-color: var(--gold); }
  .enp-n { flex: 0 0 auto; width: 22px; height: 22px; border-radius: 50%; background: var(--gold); color: #16204a;
    display: grid; place-items: center; font-weight: 800; font-size: .72rem; font-variant-numeric: tabular-nums; }

  @media (max-width: 720px) {
    .enp-chips { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .enp-chip { justify-content: flex-start; min-height: 46px; }
  }
</style>

<script is:inline>
  (function () {
    var section = document.getElementById('projects');
    if (!section) return;
    // engagement signal (not a conversion) → Clarity / Meta / dataLayer via the shared wrapper
    section.querySelectorAll('[data-proj]').forEach(function (el) {
      el.addEventListener('click', function () {
        if (window.track) window.track('project_click', { project: el.getAttribute('data-proj') });
      });
    });
    // Play the masterplan video only while it's on screen — defers the download (preload=metadata,
    // no autoplay), stops it decoding when scrolled away, and stays paused on the poster for
    // prefers-reduced-motion (WCAG 2.2.2).
    var vid = section.querySelector('.enp-video');
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (vid && !reduce && 'IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { vid.play().catch(function () {}); }
          else { vid.pause(); }
        });
      }, { threshold: 0.25 });
      io.observe(vid);
    }
  })();
</script>
