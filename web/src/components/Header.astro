---
interface Props { variant?: "main" | "sub"; }
const { variant = "main" } = Astro.props;
---
<header class="site-header">
  <a class="brand" href="/"><b>Elegant</b> Nivasa</a>

  {variant === "main" ? (
    <nav class="nav-links">
      <a href="#project">The Project</a>
      <a href="#amenities">Amenities</a>
      <a href="#plans">Floor Plans</a>
      <a href="#gallery">Gallery</a>
      <a href="#location">Location</a>
      <a class="btn btn--rust" href="#enquire">Enquire</a>
    </nav>
  ) : (
    <a href="/" style="text-decoration:none;font-size:.92rem;color:var(--muted)">Explore the full project →</a>
  )}
</header>
