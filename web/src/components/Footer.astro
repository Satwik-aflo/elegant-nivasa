---
import { site } from "../config/site";
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="wrap">
    <strong style="color:#fff;font-size:1.1rem;font-family:var(--serif)">{site.name}</strong>
    <p style="margin:.5rem 0 0">By {site.developer} · {site.locality}, {site.city}</p>
    <p class="legal">
      RERA {site.rera} · HMDA &amp; RERA approved. Images, plans and figures are
      indicative and subject to change; this is a marketing communication and does
      not constitute an offer. © {year} {site.developer}.
    </p>
  </div>
</footer>
