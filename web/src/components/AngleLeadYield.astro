---
// Bespoke angle-lead block for /rental-yield — the earnings build-up (ADR-0002 B2),
// shown as a horizontal bar graph: bar length is proportional to rent collected
// by that year. Fills grow when the card reveals (.in) — no [data-bar] needed.
import { ANGLES } from "../data/comparison.ts";
const d = ANGLES.yield.lead;
if (d.kind !== "yield") throw new Error("yield angle-lead expected");
---
<section class="section al al-yield" id="angle">
  <div class="wrap">
    <div class="shead reveal">
      <p class="eyebrow">{d.eyebrow}</p>
      <h2 class="h2">{d.headline}</h2>
      <p class="lead">{d.sub}</p>
    </div>
    <div class="al-build reveal d1">
      <ol class="yl-chart">
        {d.steps.map((s) => (
          <li class="yl-row">
            <span class="yl-yr">{s.year}</span>
            <span class="yl-track"><span class="yl-fill" style={`--w:${s.pct}%`}></span></span>
            <span class="yl-val">{s.amount}</span>
          </li>
        ))}
      </ol>
      <div class="yl-foot">
        <div class="yl-total"><span class="yl-total-k">Collected by 2032</span><span class="yl-total-v">{d.total}</span></div>
        <p class="yl-them">{d.themNote}</p>
      </div>
    </div>
  </div>
</section>
