---
// Main-site Lead form → POST /api/lead → D1 + Resend. Client-side validation,
// honeypot, and a lead_submit Conversion event on success.
---
<form id="lead-form" novalidate>
  <div class="field">
    <label for="lf-name">Name</label>
    <input class="input" id="lf-name" name="name" autocomplete="name" required />
    <span class="form-err">Please enter your name</span>
  </div>
  <div class="field">
    <label for="lf-phone">Mobile</label>
    <input class="input" id="lf-phone" name="phone" inputmode="numeric" autocomplete="tel" placeholder="10-digit mobile" required />
    <span class="form-err">Enter a valid 10-digit Indian mobile</span>
  </div>
  <div class="field">
    <label for="lf-email">Email <span class="muted">(optional)</span></label>
    <input class="input" id="lf-email" name="email" type="email" autocomplete="email" />
    <span class="form-err">Enter a valid email</span>
  </div>
  <div class="field">
    <label for="lf-unit">Configuration <span class="muted">(optional)</span></label>
    <select class="input" id="lf-unit" name="unit">
      <option value="">Any / not sure</option>
      <option>2 BHK · 1,375 sft</option>
      <option>3 BHK · 1,700 sft</option>
      <option>3 BHK · 1,845 sft</option>
      <option>3 BHK · 2,205 sft</option>
    </select>
  </div>
  <div class="field">
    <label for="lf-msg">Message <span class="muted">(optional)</span></label>
    <textarea class="input" id="lf-msg" name="message" rows="3"></textarea>
  </div>

  <!-- honeypot: hidden from humans; bots fill it and get silently dropped -->
  <input type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true"
         style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0" />

  <button class="btn btn--rust btn--block btn--lg" type="submit">Get the price sheet &amp; brochure</button>
  <p class="form-note">We'll send the brochure to your WhatsApp. No spam.</p>
</form>

<div class="form-success" id="lead-success" hidden>
  Thanks — we've got your details and a sales lead will reach out shortly. Your brochure is on its way to WhatsApp.
</div>

<script>
  const form = document.getElementById("lead-form") as HTMLFormElement | null;
  const successEl = document.getElementById("lead-success");
  if (form) {
    const get = (n: string) => form.querySelector<HTMLInputElement>(`[name="${n}"]`)!;
    const nameEl = get("name"), phoneEl = get("phone"), emailEl = get("email");
    const mark = (el: HTMLElement, bad: boolean) =>
      el.closest(".field")?.classList.toggle("field--error", bad);

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      let ok = true;
      const nameBad = !nameEl.value.trim(); mark(nameEl, nameBad); ok &&= !nameBad;
      const phoneBad = !/^[6-9]\d{9}$/.test(phoneEl.value.trim()); mark(phoneEl, phoneBad); ok &&= !phoneBad;
      const emailBad = !!emailEl.value && !/^\S+@\S+\.\S+$/.test(emailEl.value); mark(emailEl, emailBad); ok &&= !emailBad;
      if (!ok) return;

      const data: Record<string, string> = Object.fromEntries(new FormData(form) as any);
      data.source_page = location.pathname;
      data.utm = location.search;

      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;
      const original = btn.textContent;
      btn.disabled = true; btn.textContent = "Sending…";
      try {
        const res = await fetch("/api/lead", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error(String(res.status));
        form.hidden = true;
        if (successEl) successEl.hidden = false;
        (window as any).track?.("lead_submit", { unit: data.unit || "" });
      } catch {
        btn.disabled = false; btn.textContent = original || "Try again";
      }
    });
  }
</script>
